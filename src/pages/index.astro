---
import Nav         from '../components/Nav.astro';
import Hero        from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ShelfCard   from '../components/ShelfCard.astro';
import ContactForm from '../components/ContactForm.astro';
import '../styles/global.css';

import projects from '../content/projects.json';
import shelfRaw from '../content/shelf.json';

const shelf = [...shelfRaw].sort((a, b) =>
  new Date(b.dateAdded).getTime() - new Date(a.dateAdded).getTime()
);
const shelfTypes = ['All', ...[...new Set(shelf.map(item => item.type))].sort()];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Max Cattarello — product builder at the intersection of technology and human behaviour."
    />
    <meta property="og:title"       content="Max Cattarello" />
    <meta property="og:description" content="Product builder at the intersection of technology and human behaviour." />
    <meta property="og:type"        content="website" />
    <title>Max Cattarello</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>

  <body>
    <Nav />

    <main>

      <!-- ── #home ──────────────────────────────────────────── -->
      <Hero />

      <!-- ── #projects ──────────────────────────────────────── -->
      <section id="projects" class="section">
        <div class="container">
          <h2 class="section-heading">Projects</h2>

          <div class="projects-tabs" role="tablist" aria-label="Project type filter">
            <button
              class="projects-tab projects-tab--active"
              role="tab"
              aria-selected="true"
              data-tab="work"
            >
              Work
            </button>
            <button
              class="projects-tab"
              role="tab"
              aria-selected="false"
              data-tab="side"
            >
              Side Projects
            </button>
          </div>

          <div class="cards-grid" id="projects-grid" role="tabpanel">
            {projects.map(p => (
              <ProjectCard
                title={p.title}
                description={p.description}
                tags={p.tags}
                link={p.link}
                period={p.period}
                type={p.type as 'work' | 'side'}
              />
            ))}
          </div>
        </div>
      </section>

      <!-- ── #shelf ─────────────────────────────────────────── -->
      <section id="shelf" class="section section--subtle">
        <div class="container">
          <h2 class="section-heading">My Shelf</h2>

          <div class="shelf-filters" role="tablist" aria-label="Shelf type filter">
            {shelfTypes.map((type, i) => (
              <button
                class={`shelf-pill${i === 0 ? ' shelf-pill--active' : ''}`}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                data-shelf-filter={type}
              >
                {type}
              </button>
            ))}
          </div>

          <div class="cards-grid" id="shelf-grid">
            {shelf.map((item, i) => (
              <ShelfCard
                type={item.type}
                title={item.title}
                credit={item.credit}
                topic={item.topic}
                note={item.note}
                link={item.link}
                index={i}
              />
            ))}
          </div>

          {shelf.length > 3 && (
            <div class="shelf-expand">
              <button class="shelf-expand__btn" id="shelf-expand-btn">
                Show more
              </button>
            </div>
          )}
        </div>
      </section>

      <!-- ── #write ─────────────────────────────────────────── -->
      <section id="write" class="section">
        <div class="container">
          <h2 class="section-heading">Write Me</h2>

          <div class="contact-grid">
            <div>
              <p class="contact-intro">
                Whether you're building something interesting, want to compare
                notes on a book, or just want to say hello — I'd love to hear
                from you. I try to reply to everything.
              </p>
              <a
                href="https://www.linkedin.com/in/massimiliano-cattarello/"
                class="btn-linkedin"
                target="_blank"
                rel="noopener noreferrer"
              >
                Connect on LinkedIn
              </a>
            </div>

            <ContactForm />
          </div>
        </div>
      </section>

    </main>

    <footer class="footer">
      <div class="container">
        <p>&copy; 2026 Max Cattarello</p>
      </div>
    </footer>

  </body>
</html>

<script>
  // ── Projects tab filter ────────────────────────────────────
  const tabs  = document.querySelectorAll<HTMLButtonElement>('.projects-tab');
  const cards = document.querySelectorAll<HTMLElement>('.project-card');

  cards.forEach(card => {
    if (card.dataset.type !== 'work') card.style.display = 'none';
  });

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      tabs.forEach(t => {
        t.classList.toggle('projects-tab--active', t === tab);
        t.setAttribute('aria-selected', String(t === tab));
      });
      cards.forEach(card => {
        card.style.display = card.dataset.type === target ? '' : 'none';
      });
    });
  });

  // ── Shelf filter pills + expand ────────────────────────────
  const pills      = document.querySelectorAll<HTMLButtonElement>('.shelf-pill');
  const shelfCards = document.querySelectorAll<HTMLElement>('.shelf-card');
  const expandBtn  = document.getElementById('shelf-expand-btn') as HTMLButtonElement | null;
  const LIMIT      = 3;
  let expanded     = false;
  let activeFilter = 'All';

  function applyShelfView() {
    let visible = 0;
    shelfCards.forEach(card => {
      const matchesFilter = activeFilter === 'All' || card.dataset.type === activeFilter;
      const withinLimit   = activeFilter !== 'All' || expanded || visible < LIMIT;

      if (matchesFilter && withinLimit) {
        card.style.display = '';
        visible++;
      } else if (matchesFilter && !withinLimit) {
        card.style.display = 'none';
      } else {
        card.style.display = 'none';
      }
    });

    if (expandBtn) {
      const total = activeFilter === 'All'
        ? shelfCards.length
        : [...shelfCards].filter(c => c.dataset.type === activeFilter).length;
      expandBtn.parentElement!.style.display =
        !expanded && activeFilter === 'All' && total > LIMIT ? '' : 'none';
    }
  }

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      activeFilter = pill.dataset.shelfFilter ?? 'All';
      expanded = false;
      pills.forEach(p => {
        p.classList.toggle('shelf-pill--active', p === pill);
        p.setAttribute('aria-selected', String(p === pill));
      });
      applyShelfView();
    });
  });

  expandBtn?.addEventListener('click', () => {
    expanded = true;
    applyShelfView();
  });

  applyShelfView();
</script>
