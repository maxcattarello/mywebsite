---
import Nav         from '../components/Nav.astro';
import Hero        from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ShelfCard   from '../components/ShelfCard.astro';
import ContactForm from '../components/ContactForm.astro';
import ScrollHint  from '../components/ScrollHint.astro';
import '../styles/global.css';

import projects from '../content/projects.json';
import shelfRaw from '../content/shelf.json';

const shelf = [...shelfRaw].sort((a, b) =>
  new Date(b.dateAdded).getTime() - new Date(a.dateAdded).getTime()
);
const shelfTypes = ['All', ...[...new Set(shelf.map(item => item.type))].sort()];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Max Cattarello — product builder at the intersection of technology and human behaviour."
    />
    <meta property="og:title"       content="Max Cattarello" />
    <meta property="og:description" content="Product builder at the intersection of technology and human behaviour." />
    <meta property="og:type"        content="website" />
    <title>Max Cattarello</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>

  <body>
    <Nav />

    <main>

      <!-- ── #home ──────────────────────────────────────────── -->
      <Hero />

      <!-- ── #projects ──────────────────────────────────────── -->
      <section id="projects" class="section">
        <div class="container">
          <h2 class="section-heading">Projects</h2>

          <div class="shelf-filters" role="tablist" aria-label="Project type filter">
            <button class="shelf-pill shelf-pill--active" role="tab" aria-selected="true" data-project-filter="all">All</button>
            <button class="shelf-pill" role="tab" aria-selected="false" data-project-filter="work">Work-related</button>
            <button class="shelf-pill" role="tab" aria-selected="false" data-project-filter="personal">Personal projects</button>
          </div>

          <div class="cards-grid" id="projects-grid">
            {projects.map(p => (
              <ProjectCard
                title={p.title}
                description={p.description}
                tags={p.tags}
                link={p.link}
                period={p.period}
                type={p.type}
              />
            ))}
          </div>
          <ScrollHint />
        </div>
      </section>

      <!-- ── #shelf ─────────────────────────────────────────── -->
      <section id="shelf" class="section section--subtle">
        <div class="container">
          <h2 class="section-heading">My Shelf</h2>

          <div class="shelf-filters" role="tablist" aria-label="Shelf type filter">
            {shelfTypes.map((type, i) => (
              <button
                class={`shelf-pill${i === 0 ? ' shelf-pill--active' : ''}`}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                data-shelf-filter={type}
              >
                {type}
              </button>
            ))}
          </div>

          <div class="cards-grid" id="shelf-grid">
            {shelf.map((item, i) => (
              <ShelfCard
                type={item.type}
                title={item.title}
                credit={item.credit}
                topic={item.topic}
                note={item.note}
                link={item.link}
                index={i}
              />
            ))}
          </div>

          {shelf.length > 3 && (
            <div class="shelf-expand">
              <button class="shelf-expand__btn" id="shelf-expand-btn">Show more</button>
              <button class="shelf-expand__btn" id="shelf-collapse-btn" style="display:none">Collapse</button>
            </div>
          )}
          <ScrollHint />
        </div>
      </section>

      <!-- ── #write ─────────────────────────────────────────── -->
      <section id="write" class="section">
        <div class="container">
          <h2 class="section-heading">Write Me</h2>

          <div class="contact-grid">
            <div>
              <p class="contact-intro">
                Whether you're building something interesting, want to compare
                notes on a book, or just want to say hello — I'd love to hear
                from you. I try to reply to everything.
              </p>
              <a
                href="https://www.linkedin.com/in/massimiliano-cattarello/"
                class="btn-linkedin"
                target="_blank"
                rel="noopener noreferrer"
              >
                Connect on LinkedIn
              </a>
            </div>

            <ContactForm />
          </div>
        </div>
      </section>

    </main>

    <footer class="footer">
      <div class="container">
        <p>&copy; 2026 Max Cattarello</p>
      </div>
    </footer>

  </body>
</html>

<script>
  // ── Shuffle shelf cards on every page load ─────────────────
  (function shuffleShelf() {
    const grid = document.getElementById('shelf-grid');
    if (!grid) return;
    const cards = [...grid.children];
    for (let i = cards.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      grid.appendChild(cards[j]);
      cards.splice(j, 1);
    }
    // Re-assign data-index so the expand logic still works correctly
    [...grid.children].forEach((card, idx) => {
      (card as HTMLElement).dataset.index = String(idx);
    });
  })();

  // ── Project filter pills ───────────────────────────────────
  const projectPills = document.querySelectorAll<HTMLButtonElement>('[data-project-filter]');
  const projectCards = document.querySelectorAll<HTMLElement>('.project-card');

  projectPills.forEach(pill => {
    pill.addEventListener('click', () => {
      const filter = pill.dataset.projectFilter ?? 'all';
      projectPills.forEach(p => {
        p.classList.toggle('shelf-pill--active', p === pill);
        p.setAttribute('aria-selected', String(p === pill));
      });
      projectCards.forEach(card => {
        card.style.display = filter === 'all' || card.dataset.type === filter ? '' : 'none';
      });
    });
  });

  // ── Shelf filter pills + expand ────────────────────────────
  const pills      = document.querySelectorAll<HTMLButtonElement>('.shelf-pill');
  const shelfCards = document.querySelectorAll<HTMLElement>('.shelf-card');
  const expandBtn   = document.getElementById('shelf-expand-btn') as HTMLButtonElement | null;
  const collapseBtn = document.getElementById('shelf-collapse-btn') as HTMLButtonElement | null;
  const LIMIT       = 3;
  let expanded      = false;
  let activeFilter  = 'All';

  function applyShelfView() {
    let visible = 0;
    shelfCards.forEach(card => {
      const matchesFilter = activeFilter === 'All' || card.dataset.type === activeFilter;
      const withinLimit   = activeFilter !== 'All' || expanded || visible < LIMIT;

      if (matchesFilter && withinLimit) {
        card.style.display = '';
        visible++;
      } else {
        card.style.display = 'none';
      }
    });

    const total = activeFilter === 'All'
      ? shelfCards.length
      : [...shelfCards].filter(c => c.dataset.type === activeFilter).length;
    const showButtons = activeFilter === 'All' && total > LIMIT;

    if (expandBtn)   expandBtn.style.display   = showButtons && !expanded ? '' : 'none';
    if (collapseBtn) collapseBtn.style.display = showButtons && expanded  ? '' : 'none';
  }

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      activeFilter = pill.dataset.shelfFilter ?? 'All';
      expanded = false;
      pills.forEach(p => {
        p.classList.toggle('shelf-pill--active', p === pill);
        p.setAttribute('aria-selected', String(p === pill));
      });
      applyShelfView();
    });
  });

  expandBtn?.addEventListener('click', () => {
    expanded = true;
    applyShelfView();
  });

  collapseBtn?.addEventListener('click', () => {
    expanded = false;
    applyShelfView();
    document.getElementById('shelf')?.scrollIntoView({ behavior: 'smooth' });
  });

  applyShelfView();
</script>
