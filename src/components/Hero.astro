---
---

<section id="home" class="hero" aria-label="Introduction">
  <div class="container">
    <div class="hero__content">

      <!-- Left: text -->
      <div class="hero__text">
        <p class="section-label hero__label">001 — ABOUT</p>

        <h1 class="hero__name">
          <em>Max.</em>
        </h1>

        <p class="hero__tagline">
          Builder. Product thinker. Occasionally right.
        </p>

        <p class="hero__intro">
          I build products at the intersection of technology and human behaviour.
          Currently focused on AI-native tools that make complex work feel effortless.
          Previously: growth, developer experience, and a few things that didn't work out.
        </p>

        <div class="hero__social" aria-label="Social links">
          <a
            href="https://linkedin.com/in/maxcattarello"
            class="hero__social-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn profile"
          >
            <!-- LinkedIn icon -->
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>

          <a
            href="https://x.com/maxcattarello"
            class="hero__social-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="X / Twitter profile"
          >
            <!-- X / Twitter icon -->
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
            X / Twitter
          </a>
        </div>
      </div>

      <!-- Right: photo -->
      <div class="hero__photo-wrap">
        <img
          src="/photo.jpg"
          alt="A photo of Max Cattarello"
          class="hero__photo"
          width="480"
          height="600"
          id="hero-photo"
        />
        <!-- Shown if photo.jpg is missing -->
        <div class="hero__photo-placeholder" id="hero-placeholder" style="display:none">
          <span>📷</span>
          <span>Add your photo to</span>
          <code>public/photo.jpg</code>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  // Show placeholder if photo fails to load
  const photo       = document.getElementById('hero-photo') as HTMLImageElement;
  const placeholder = document.getElementById('hero-placeholder') as HTMLElement;

  if (photo) {
    photo.addEventListener('error', () => {
      photo.style.display = 'none';
      if (placeholder) placeholder.style.display = 'flex';
    });
  }
</script>
