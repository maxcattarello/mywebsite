---
import { Image }   from 'astro:assets';
import photo       from '../assets/photo.jpg';
import ScrollHint  from './ScrollHint.astro';
---

<section id="home" class="hero" aria-label="Introduction">
  <div class="container">
    <div class="hero__content">

      <!-- Left: text -->
      <div class="hero__text">
<h1 class="hero__name">
          <em>Max.</em>
        </h1>

        <p class="hero__tagline">
          Builder. Product thinker. Occasionally right.
        </p>

        <p class="hero__intro">
          I'm a technologist, strategist, and chronic idea-generator. For the past decade
          I've worked at the intersection of data, analytics, and business, most recently
          in a global role at KPMG focused on revenue growth and pricing strategy. On the side,
          I build side projects, read obsessively, and believe AI is the most interesting
          thing happening in the world right now.
        </p>

      </div>

      <!-- Right: photo -->
      <div class="hero__photo-wrap">
        <Image
          src={photo}
          alt="A photo of Max Cattarello"
          class="hero__photo"
          width={480}
          height={480}
          id="hero-photo"
        />
        <!-- Shown if photo.jpg is missing -->
        <div class="hero__photo-placeholder" id="hero-placeholder" style="display:none">
          <span>📷</span>
          <span>Add your photo to</span>
          <code>public/photo.jpg</code>
        </div>
      </div>

    </div>
    <ScrollHint />
  </div>
</section>

<script>
  // Show placeholder if photo fails to load
  const photo       = document.getElementById('hero-photo') as HTMLImageElement;
  const placeholder = document.getElementById('hero-placeholder') as HTMLElement;

  if (photo) {
    photo.addEventListener('error', () => {
      photo.style.display = 'none';
      if (placeholder) placeholder.style.display = 'flex';
    });
  }
</script>
