---
const links = [
  { href: '#home',     label: 'About'     },
  { href: '#projects', label: 'Projects'  },
  { href: '#shelf',    label: 'My Shelf'  },
  { href: '#write',    label: 'Write Me'  },
];
---

<nav class="nav" id="main-nav" aria-label="Main navigation">
  <div class="nav__inner">

    <div class="nav__left">
      <a href="#home" class="nav__logo">Max Cattarello</a>
      <div class="nav__status" id="nav-status" aria-label="Current status">
        <span class="status-dot" id="status-dot"></span>
        <span class="status-text" id="status-text"></span>
        <div class="status-tooltip" id="status-tooltip" role="tooltip" aria-hidden="true"></div>
      </div>
    </div>

    <div class="nav__right">
      <ul class="nav__links" role="list">
        {links.map(({ href, label }) => (
          <li>
            <a href={href} class="nav__link">{label}</a>
          </li>
        ))}
      </ul>

      <button class="theme-toggle" id="theme-toggle" aria-label="Switch to dark mode">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="2" x2="12" y2="4"/>
          <line x1="12" y1="20" x2="12" y2="22"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="2" y1="12" x2="4" y2="12"/>
          <line x1="20" y1="12" x2="22" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <button
        class="nav__hamburger"
        id="hamburger"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="nav-overlay"
      >
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>

  </div>
</nav>

<div class="nav__overlay" id="nav-overlay" aria-hidden="true">
  <ul role="list">
    {links.map(({ href, label }) => (
      <li>
        <a href={href} class="nav__overlay-link">{label}</a>
      </li>
    ))}
  </ul>
</div>

<script>
  // ── Status widget ────────────────────────────────────────────
  const dotPool   = ['green', 'green', 'green', 'amber', 'amber', 'red'] as const;
  const dotColors = { green: '#7ab648', amber: '#EF9F27', red: '#E24B4A' };

  const statusSlots = [
    { opts: [
      'surviving on the first coffee',
      'reading a book',
      'checking emails',
      'mentally still in bed',
      'negotiating with the alarm clock',
    ]},
    { opts: [
      'deep in the code trenches',
      "in a meeting that could've been an email",
      'debugging something I vibe-coded yesterday',
      'actually productive for once',
      'on my third coffee, no regrets',
    ]},
    { opts: [
      'eating at the desk like a professional',
      'running 5k instead of having lunch',
      'scrolling tech twitter instead of eating',
      'reheating something questionable',
      '30min break, see you in 90',
    ]},
    { opts: [
      'fighting the post-lunch slump',
      'in flow state, do not disturb',
      'procrastinating productively',
      'refactoring code no one asked me to refactor',
      'counting down to 6pm',
    ]},
    { opts: [
      'finally doing the side project',
      "watching tutorials I won't finish",
      'cooking something ambitious',
      'pretending I am eating something very healthy',
      'open to interesting conversations',
    ]},
    { opts: [
      'one more episode',
      'reading documentation at an unreasonable hour',
      'reading a book',
      'having my best ideas with nowhere to write them',
      'winding down',
    ]},
    { opts: [
      'should not be awake right now',
      'on a legendary coding streak',
      'losing a battle with insomnia',
      "watching something I've already seen",
      'catching up on sleep',
    ]},
  ];

  function getSlot(): number {
    const h = new Date().getHours();
    if (h >= 7  && h < 9)  return 0;
    if (h >= 9  && h < 12) return 1;
    if (h >= 12 && h < 14) return 2;
    if (h >= 14 && h < 18) return 3;
    if (h >= 18 && h < 21) return 4;
    if (h >= 21)            return 5;
    return 6;
  }

  const statusOpt = statusSlots[getSlot()].opts[Math.floor(Math.random() * 5)];
  const dotColor  = dotColors[dotPool[Math.floor(Math.random() * dotPool.length)]];

  const statusDot  = document.getElementById('status-dot')!;
  const statusText = document.getElementById('status-text')!;
  const statusTip  = document.getElementById('status-tooltip')!;
  const navStatus  = document.getElementById('nav-status')!;

  statusDot.style.backgroundColor = dotColor;
  statusText.textContent = statusOpt;
  statusTip.textContent  = statusOpt;

  // Mobile: tap dot area to show/hide tooltip
  navStatus.addEventListener('click', (e) => {
    if (window.innerWidth > 640) return;
    e.stopPropagation();
    const isOpen = statusTip.classList.contains('status-tooltip--open');
    statusTip.classList.toggle('status-tooltip--open', !isOpen);
    statusTip.setAttribute('aria-hidden', String(isOpen));
  });

  document.addEventListener('click', () => {
    statusTip.classList.remove('status-tooltip--open');
    statusTip.setAttribute('aria-hidden', 'true');
  });

  // ── Theme toggle ─────────────────────────────────────────────
  function playDaySound(): void {
    const ctx   = new (window.AudioContext || (window as any).webkitAudioContext)();
    const freqs = [523, 659, 784];
    freqs.forEach((f, i) => {
      const osc  = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.type = 'sine';
      osc.frequency.value = f;
      const t = ctx.currentTime + i * 0.08;
      gain.gain.setValueAtTime(0, t);
      gain.gain.linearRampToValueAtTime(0.18, t + 0.03);
      gain.gain.exponentialRampToValueAtTime(0.001, t + 0.25);
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.start(t);
      osc.stop(t + 0.25);
    });
  }

  function playNightSound(): void {
    const ctx  = new (window.AudioContext || (window as any).webkitAudioContext)();
    const o1   = ctx.createOscillator();
    const o2   = ctx.createOscillator();
    const gain = ctx.createGain();
    o1.type = 'sine'; o1.frequency.value = 220;
    o2.type = 'sine'; o2.frequency.value = 165;
    gain.gain.setValueAtTime(0.15, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.9);
    o1.connect(gain); o2.connect(gain); gain.connect(ctx.destination);
    o1.start(); o2.start();
    o1.stop(ctx.currentTime + 0.9);
    o2.stop(ctx.currentTime + 0.9);
    const buf  = ctx.createBuffer(1, ctx.sampleRate * 0.4, ctx.sampleRate);
    const data = buf.getChannelData(0);
    for (let i = 0; i < data.length; i++) {
      data[i] = (Math.random() * 2 - 1) * Math.exp(-i / (ctx.sampleRate * 0.1)) * 0.04;
    }
    const src = ctx.createBufferSource();
    src.buffer = buf;
    src.connect(ctx.destination);
    src.start();
  }

  const themeToggle = document.getElementById('theme-toggle')!;
  const sunIcon     = themeToggle.querySelector('.icon-sun')  as HTMLElement;
  const moonIcon    = themeToggle.querySelector('.icon-moon') as HTMLElement;

  let isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

  function applyTheme(): void {
    document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
    sunIcon.style.display  = isDark ? 'none'  : 'block';
    moonIcon.style.display = isDark ? 'block' : 'none';
    themeToggle.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
  }

  applyTheme(); // sync icons to system preference on load (no sound)

  themeToggle.addEventListener('click', () => {
    isDark = !isDark;
    applyTheme();
    if (isDark) playNightSound();
    else        playDaySound();
  });

  // ── Nav scroll / menu ────────────────────────────────────────
  const nav       = document.getElementById('main-nav')!;
  const hamburger = document.getElementById('hamburger')!;
  const overlay   = document.getElementById('nav-overlay')!;

  window.addEventListener('scroll', () => {
    nav.classList.toggle('nav--scrolled', window.scrollY > 20);
  }, { passive: true });

  function openMenu(): void {
    overlay.classList.add('nav__overlay--open');
    overlay.setAttribute('aria-hidden', 'false');
    hamburger.setAttribute('aria-expanded', 'true');
    hamburger.setAttribute('aria-label', 'Close menu');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu(): void {
    overlay.classList.remove('nav__overlay--open');
    overlay.setAttribute('aria-hidden', 'true');
    hamburger.setAttribute('aria-expanded', 'false');
    hamburger.setAttribute('aria-label', 'Open menu');
    document.body.style.overflow = '';
  }

  hamburger.addEventListener('click', () => {
    const isOpen = overlay.classList.contains('nav__overlay--open');
    isOpen ? closeMenu() : openMenu();
  });

  overlay.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', (e) => {
      const href = (anchor as HTMLAnchorElement).getAttribute('href');
      if (!href) return;
      const target = document.querySelector(href);
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });
</script>
